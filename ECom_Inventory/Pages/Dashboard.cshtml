@page
@model ECom_Inventory.Pages.DashboardModel
@{
    Layout = "_Layout"; // Use the shared layout
    ViewData["Title"] = "Dashboard";
}

<h1 class="h3 mb-3">Dashboard</h1>

<div class="row">
    <!-- Manage Products Card -->
    <div class="col-md-6 mb-4">
        <div class="card dashboard-card-1 h-100">
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                <i data-feather="box" class="mb-3" style="width: 48px; height: 48px; color: #3b82f6;"></i>
                <h3 class="mb-3 text-dark">Manage Products</h3>
                <a href="/Ecom/ManageProduct" class="btn btn-primary px-5 rounded-pill shadow-sm">Go to Products</a>
            </div>
        </div>
    </div>

    <!-- View Profile Card -->
    <div class="col-md-6 mb-4">
        <div class="card dashboard-card-2 h-100">
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                <i data-feather="user" class="mb-3" style="width: 48px; height: 48px; color: #64748b;"></i>
                <h3 class="mb-3 text-dark">View Profile</h3>
                <a href="/Auth/Profile" class="btn btn-secondary px-5 rounded-pill shadow-sm">Go to Profile</a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Suppliers Card -->
    <div class="col-md-6 mb-4">
        <div class="card dashboard-card-2 h-100">
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                <i data-feather="truck" class="mb-3" style="width: 48px; height: 48px; color: #10b981;"></i>
                <h3 class="mb-3 text-dark">Suppliers</h3>
                <a href="/Ecom/Suppliers" class="btn btn-info px-5 rounded-pill shadow-sm text-white">View Suppliers</a>
            </div>
        </div>
    </div>

    <!-- Manage Users Card (Admin Only) -->
    <div class="col-md-6 mb-4">
        <div class="card dashboard-card-1 h-100">
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                <i data-feather="users" class="mb-3" style="width: 48px; height: 48px; color: #ef4444;"></i>
                <h3 class="mb-3 text-dark">Manage Users <small class="text-muted d-block mt-1" style="font-size: 0.75rem;">(Admin Only)</small></h3>
                <a href="/Auth/AddUser" class="btn btn-danger px-5 rounded-pill shadow-sm">User Management</a>
            </div>
        </div>
    </div>
</div>

<!-- Additional Cards for Brands and Product Types -->
<div class="row">
    <!-- Brands Card -->
    <div class="col-md-6 mb-4">
        <div class="card dashboard-card-1 h-100">
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                <i data-feather="tag" class="mb-3" style="width: 48px; height: 48px; color: #f59e0b;"></i>
                <h3 class="mb-3 text-dark">Brands</h3>
                <a href="/Ecom/Brands" class="btn btn-warning px-5 text-white rounded-pill shadow-sm">View Brands</a>
            </div>
        </div>
    </div>

    <!-- Product Types Card -->
    <div class="col-md-6 mb-4">
        <div class="card dashboard-card-2 h-100">
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                <i data-feather="layers" class="mb-3" style="width: 48px; height: 48px; color: #14b8a6;"></i>
                <h3 class="mb-3 text-dark">Product Types</h3>
                <a href="/Ecom/ProductTypes" class="btn btn-success px-5 rounded-pill shadow-sm">View Types</a>
            </div>
        </div>
    </div>
</div>